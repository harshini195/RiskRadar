# Copy to .env and fill in your keys
# cp .env.example .env

# Google Maps API Key (enable: Maps JS API, Directions API, Geometry library)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Flask secret key
SECRET_KEY=change-me-in-production

# PostgreSQL (used by backend directly if not using Docker)
DATABASE_URL=postgresql://postgres:password@localhost:5432/riskradar
